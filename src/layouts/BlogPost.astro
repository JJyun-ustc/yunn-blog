---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Comments from '../components/Comments.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import CodeCopy from '../components/CodeCopy.astro';
import { withBase } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & {
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: string;
  wordCount?: string;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  tags,
  headings = [],
  readingTime,
  wordCount,
  prevPost,
  nextPost,
} = Astro.props;

const heroImageSrc =
  typeof heroImage === 'string'
    ? heroImage.startsWith('http')
      ? heroImage
      : withBase(heroImage.replace(/^\/+/, ''))
    : null;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <ReadingProgress />
    <Header />
    <main class="post-main shell">
      <article class="post-shell">
        {heroImage && (
          <div class="hero-image">
            {typeof heroImage === 'string' ? (
              <img src={heroImageSrc!} alt={title} loading="eager" />
            ) : (
              <Image width={1400} height={620} src={heroImage} alt={title} />
            )}
          </div>
        )}

        <div class="post-layout">
          <aside class="post-rail rail-left">
            <div class="side-card">
              <h3>Article Pulse</h3>
              <div class="pulse-bars">
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
              </div>
            </div>
            {tags && tags.length > 0 && (
              <div class="side-card">
                <h3>Tags</h3>
                <div class="pill-list">
                  {tags.map((tag: string) => (
                    <a href={withBase(`tags/${encodeURIComponent(tag)}/`)}>{tag}</a>
                  ))}
                </div>
              </div>
            )}
          </aside>

          <div class="post-content">
            <header class="post-header page-hero">
              <div class="post-meta">
                {category && (
                  <a href={withBase(`categories/${encodeURIComponent(category)}/`)} class="category-link">
                    {category}
                  </a>
                )}
                <FormattedDate date={pubDate} />
                {readingTime && (
                  <span class="reading-time">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {readingTime}
                  </span>
                )}
                {wordCount && (
                  <span class="word-count">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    {wordCount}
                  </span>
                )}
              </div>
              <h1>{title}</h1>
              {description && <p class="post-description">{description}</p>}
              {updatedDate && (
                <p class="updated-date">
                  更新于 <FormattedDate date={updatedDate} />
                </p>
              )}
            </header>

            <div class="prose card-surface">
              <slot />
            </div>

            {tags && tags.length > 0 && (
              <footer class="post-footer card-surface">
                <div class="post-tags">
                  <span class="tags-label">标签：</span>
                  {tags.map((tag: string) => (
                    <a href={withBase(`tags/${encodeURIComponent(tag)}/`)} class="tag">{tag}</a>
                  ))}
                </div>
              </footer>
            )}

            {(prevPost || nextPost) && (
              <nav class="post-navigation">
                {prevPost && (
                  <a href={withBase(`blog/${prevPost.id}/`)} class="nav-link nav-prev">
                    <span class="nav-label">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                      </svg>
                      上一篇
                    </span>
                    <span class="nav-title">{prevPost.data.title}</span>
                  </a>
                )}
                {nextPost && (
                  <a href={withBase(`blog/${nextPost.id}/`)} class="nav-link nav-next">
                    <span class="nav-label">
                      下一篇
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                      </svg>
                    </span>
                    <span class="nav-title">{nextPost.data.title}</span>
                  </a>
                )}
              </nav>
            )}

            <Comments />
          </div>

          <aside class="post-rail rail-right">
            <div class="post-sidebar">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        </div>
      </article>
    </main>
    <ImageLightbox />
    <CodeCopy />
    <Footer />
  </body>
</html>

<style>
  .post-main {
    max-width: var(--site-max);
    padding-top: 0;
  }

  .post-shell {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-image {
    width: 100%;
    max-height: 460px;
    overflow: hidden;
    border-radius: 0 0 28px 28px;
    box-shadow: 0 20px 40px var(--shadow);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  .post-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.55fr) minmax(0, var(--content-max)) minmax(240px, 0.62fr);
    justify-content: center;
    gap: 1.25rem;
    align-items: start;
  }

  .post-rail {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 5.75rem;
  }

  .post-content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .post-header {
    text-align: center;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    flex-wrap: wrap;
  }

  .reading-time,
  .word-count {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .category-link {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    padding: 0.28rem 0.78rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .post-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .post-description {
    margin: 0 auto 0.75rem;
    max-width: 40rem;
    color: var(--text-secondary);
  }

  .updated-date {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .prose {
    color: var(--text);
    line-height: 1.85;
  }

  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    background: rgba(255, 255, 255, 0.34);
    border-left: 4px solid var(--primary);
    border-radius: 0 14px 14px 0;
  }

  .prose :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: 14px;
    overflow-x: auto;
  }

  .prose :global(img) {
    margin: 1.5rem 0;
    border-radius: 16px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .tags-label {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 22px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    box-shadow: 0 12px 24px var(--shadow);
  }

  .nav-link:hover {
    border-color: var(--primary);
    box-shadow: 0 18px 28px var(--shadow-strong);
    transform: translateY(-2px);
  }

  .nav-prev {
    align-items: flex-start;
    text-align: left;
  }

  .nav-next {
    align-items: flex-end;
    text-align: right;
  }

  .nav-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .nav-title {
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .post-sidebar {
    position: sticky;
    top: 0;
  }

  @media (max-width: 1200px) {
    .post-layout {
      grid-template-columns: minmax(0, var(--content-max)) minmax(250px, 0.7fr);
    }

    .rail-left {
      display: none;
    }
  }

  @media (max-width: 960px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-rail {
      position: static;
    }

    .rail-right {
      order: 3;
    }
  }

  @media (max-width: 640px) {
    .post-navigation {
      grid-template-columns: 1fr;
    }
  }

  .pulse-bars { display: flex; align-items: flex-end; justify-content: center; gap: 8px; height: 120px; padding: 1rem 0; }
  .pulse-bars .bar {
    width: 16px;
    border-radius: 8px;
    animation: pulseBeat 1.2s ease-in-out infinite;
    transform-origin: bottom;
  }
  .pulse-bars .bar:nth-child(1) { height: 40%; background: linear-gradient(to top, #f97316, #fbbf24); animation-delay: 0s; }
  .pulse-bars .bar:nth-child(2) { height: 70%; background: linear-gradient(to top, #ec4899, #f472b6); animation-delay: 0.15s; }
  .pulse-bars .bar:nth-child(3) { height: 55%; background: linear-gradient(to top, #8b5cf6, #a78bfa); animation-delay: 0.3s; }
  .pulse-bars .bar:nth-child(4) { height: 90%; background: linear-gradient(to top, #06b6d4, #22d3ee); animation-delay: 0.45s; }
  .pulse-bars .bar:nth-child(5) { height: 50%; background: linear-gradient(to top, #10b981, #34d399); animation-delay: 0.6s; }
  .pulse-bars .bar:nth-child(6) { height: 75%; background: linear-gradient(to top, #f59e0b, #fcd34d); animation-delay: 0.75s; }
  .pulse-bars .bar:nth-child(7) { height: 60%; background: linear-gradient(to top, #6366f1, #818cf8); animation-delay: 0.9s; }
  @keyframes pulseBeat {
    0%, 100% { transform: scaleY(0.4); opacity: 0.6; }
    25% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.6); opacity: 0.8; }
    75% { transform: scaleY(1); opacity: 1; }
  }
</style>