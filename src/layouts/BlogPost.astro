---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Comments from '../components/Comments.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import CodeCopy from '../components/CodeCopy.astro';
import { withBase } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & {
  headings?: { depth: number; slug: string; text: string }[];
  readingTime?: string;
  wordCount?: string;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
};

const { 
  title, 
  description, 
  pubDate, 
  updatedDate, 
  heroImage, 
  category, 
  tags, 
  headings = [],
  readingTime,
  wordCount,
  prevPost,
  nextPost
} = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <ReadingProgress />
    <Header />
    <main class="post-main">
      <article>
        {heroImage && (
          <div class="hero-image">
            <Image width={1020} height={510} src={heroImage} alt={title} />
          </div>
        )}
        <div class="post-container">
          <div class="post-content">
            <header class="post-header">
              <div class="post-meta">
                {category && (
                  <a href={withBase(`categories/${encodeURIComponent(category)}/`)} class="category-link">
                    {category}
                  </a>
                )}
                <FormattedDate date={pubDate} />
                {readingTime && (
                  <span class="reading-time">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {readingTime}
                  </span>
                )}
                {wordCount && (
                  <span class="word-count">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    {wordCount}
                  </span>
                )}
              </div>
              <h1>{title}</h1>
              {updatedDate && (
                <p class="updated-date">
                  更新于 <FormattedDate date={updatedDate} />
                </p>
              )}
            </header>

            <div class="prose">
              <slot />
            </div>

            {tags && tags.length > 0 && (
              <footer class="post-footer">
                <div class="post-tags">
                  <span class="tags-label">标签：</span>
                  {tags.map((tag: string) => (
                    <a href={withBase(`tags/${encodeURIComponent(tag)}/`)} class="tag">{tag}</a>
                  ))}
                </div>
              </footer>
            )}

            {(prevPost || nextPost) && (
              <nav class="post-navigation">
                {prevPost && (
                  <a href={withBase(`blog/${prevPost.id}/`)} class="nav-link nav-prev">
                    <span class="nav-label">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                      </svg>
                      上一篇
                    </span>
                    <span class="nav-title">{prevPost.data.title}</span>
                  </a>
                )}
                {nextPost && (
                  <a href={withBase(`blog/${nextPost.id}/`)} class="nav-link nav-next">
                    <span class="nav-label">
                      下一篇
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                      </svg>
                    </span>
                    <span class="nav-title">{nextPost.data.title}</span>
                  </a>
                )}
              </nav>
            )}

            <Comments />
          </div>
          
          <aside class="post-sidebar">
            <TableOfContents headings={headings} />
          </aside>
        </div>
      </article>
    </main>
    <ImageLightbox />
    <CodeCopy />
    <Footer />
  </body>
</html>

<style>
  .post-main {
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  .post-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  .post-content {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    flex-wrap: wrap;
  }

  .reading-time, .word-count {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .reading-time svg, .word-count svg {
    width: 14px;
    height: 14px;
  }

  .category-link {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: transform 0.2s;
  }

  .category-link:hover {
    transform: scale(1.05);
  }

  .post-header h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .updated-date {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0;
  }

  .prose {
    color: var(--text);
    line-height: 1.8;
  }

  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.5rem;
    background: var(--bg-secondary);
    border-left: 4px solid var(--primary);
    border-radius: 0 8px 8px 0;
  }

  .prose :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: 8px;
    overflow-x: auto;
  }

  .prose :global(img) {
    margin: 1.5rem 0;
    border-radius: 8px;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .tags-label {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .tag {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background: var(--gradient-start);
    color: var(--primary);
    border-radius: 9999px;
    text-decoration: none;
    font-size: 0.85rem;
    transition: background-color 0.2s, color 0.2s;
  }

  .tag:hover {
    background: var(--primary);
    color: white;
  }

  .post-navigation {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .nav-link:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px var(--shadow);
    transform: translateY(-2px);
  }

  .nav-prev {
    align-items: flex-start;
    text-align: left;
  }

  .nav-next {
    align-items: flex-end;
    text-align: right;
  }

  .nav-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .nav-title {
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .nav-link:hover .nav-title {
    color: var(--primary);
  }

  @media (max-width: 640px) {
    .post-navigation {
      grid-template-columns: 1fr;
    }
  }

  .post-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  @media (max-width: 1200px) {
    .post-container {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      display: none;
    }

    .post-content {
      max-width: 720px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.5rem;
    }
  }
</style>
