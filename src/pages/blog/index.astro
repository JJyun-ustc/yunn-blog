---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts[0];
const categories = [...new Set(posts.map((post) => post.data.category || '随笔'))].slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`博客 - ${SITE_TITLE}`} description="所有文章列表" />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <span class="eyebrow">archive stream</span>
        <h1>博客文章</h1>
        <p class="page-desc">共 {posts.length} 篇文章</p>
        <div class="stat-row">
          <div class="stat-card">
            <strong>{posts.length}</strong>
            <span>total entries</span>
          </div>
          <div class="stat-card">
            <strong>{categories.length}</strong>
            <span>active groups</span>
          </div>
          <div class="stat-card">
            <strong>{latest ? latest.data.pubDate.getFullYear() : '--'}</strong>
            <span>latest year</span>
          </div>
        </div>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="section-heading-block">
              <div>
                <h2>All Posts</h2>
              </div>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>钢琴键</h3>
            <div class="piano-keys">
              <div class="piano-key white-key">C</div>
              <div class="piano-key black-key">C#</div>
              <div class="piano-key white-key">D</div>
              <div class="piano-key black-key">D#</div>
              <div class="piano-key white-key">E</div>
              <div class="piano-key white-key">F</div>
              <div class="piano-key black-key">F#</div>
              <div class="piano-key white-key">G</div>
              <div class="piano-key black-key">G#</div>
              <div class="piano-key white-key">A</div>
              <div class="piano-key black-key">A#</div>
              <div class="piano-key white-key">B</div>
            </div>
          </div>
          <div class="side-card">
            <h3>Categories</h3>
            <div class="pill-list">
              {categories.map((category) => (
                <span>{category}</span>
              ))}
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-desc { color: var(--text-muted); margin: 0 0 1.25rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .piano-keys {
    height: 120px;
    background: 
      linear-gradient(135deg, rgba(139, 69, 19, 0.15), rgba(101, 67, 33, 0.25)),
      radial-gradient(ellipse at center, rgba(139, 69, 19, 0.2), transparent 60%);
    border-radius: 20px;
    padding: 1rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 2px;
    position: relative;
  }
  .piano-key {
    width: 24px;
    height: 80px;
    border-radius: 4px 4px 8px 8px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: bold;
    color: #333;
    cursor: pointer;
    transition: all 0.1s ease;
    position: relative;
  }
  .white-key {
    background: linear-gradient(to bottom, #fff, #f5f5f5);
    border: 1px solid #ddd;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    z-index: 1;
  }
  .black-key {
    background: linear-gradient(to bottom, #333, #000);
    color: #fff;
    height: 50px;
    width: 18px;
    margin: 0 -9px;
    border-radius: 0 0 6px 6px;
    z-index: 2;
  }
  .piano-key:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.2);
  }
  .piano-key.playing {
    animation: keyPress 0.3s ease;
  }
  @keyframes keyPress {
    0% { transform: translateY(0); }
    50% { transform: translateY(-10px); background: linear-gradient(to bottom, #ffeb3b, #ffc107); }
    100% { transform: translateY(0); }
  }
  @media (max-width: 768px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
