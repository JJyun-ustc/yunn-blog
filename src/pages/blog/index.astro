---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts[0];
const categories = [...new Set(posts.map((post) => post.data.category || '随笔'))].slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`博客 - ${SITE_TITLE}`} description="所有文章列表" />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <span class="eyebrow">archive stream</span>
        <h1>博客文章</h1>
        <p class="page-desc">共 {posts.length} 篇文章</p>
        <div class="stat-row">
          <div class="stat-card">
            <strong>{posts.length}</strong>
            <span>total entries</span>
          </div>
          <div class="stat-card">
            <strong>{categories.length}</strong>
            <span>active groups</span>
          </div>
          <div class="stat-card">
            <strong>{latest ? latest.data.pubDate.getFullYear() : '--'}</strong>
            <span>latest year</span>
          </div>
        </div>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="section-heading-block">
              <div>
                <h2>All Posts</h2>
              </div>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>Quick Scan</h3>
            <div class="beat-bars">
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
            </div>
          </div>
          <div class="side-card">
            <h3>Categories</h3>
            <div class="pill-list">
              {categories.map((category) => (
                <span>{category}</span>
              ))}
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-desc { color: var(--text-muted); margin: 0 0 1.25rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .beat-bars { display: flex; align-items: flex-end; justify-content: center; gap: 6px; height: 80px; padding: 1rem 0; }
  .bar {
    width: 12px;
    border-radius: 6px;
    animation: beat 0.8s ease-in-out infinite;
  }
  .bar:nth-child(1) { height: 35%; background: linear-gradient(to top, #f97316, #fbbf24); animation-delay: 0s; }
  .bar:nth-child(2) { height: 65%; background: linear-gradient(to top, #ec4899, #f472b6); animation-delay: 0.1s; }
  .bar:nth-child(3) { height: 50%; background: linear-gradient(to top, #8b5cf6, #a78bfa); animation-delay: 0.2s; }
  .bar:nth-child(4) { height: 80%; background: linear-gradient(to top, #06b6d4, #22d3ee); animation-delay: 0.3s; }
  .bar:nth-child(5) { height: 45%; background: linear-gradient(to top, #10b981, #34d399); animation-delay: 0.4s; }
  @keyframes beat {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }
  @media (max-width: 768px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
