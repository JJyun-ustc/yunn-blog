---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = posts[0];
const categories = [...new Set(posts.map((post) => post.data.category || '随笔'))].slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`博客 - ${SITE_TITLE}`} description="所有文章列表" />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <span class="eyebrow">archive stream</span>
        <h1>博客文章</h1>
        <p class="page-desc">共 {posts.length} 篇文章</p>
        <div class="stat-row">
          <div class="stat-card">
            <strong>{posts.length}</strong>
            <span>total entries</span>
          </div>
          <div class="stat-card">
            <strong>{categories.length}</strong>
            <span>active groups</span>
          </div>
          <div class="stat-card">
            <strong>{latest ? latest.data.pubDate.getFullYear() : '--'}</strong>
            <span>latest year</span>
          </div>
        </div>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="section-heading-block">
              <div>
                <h2>All Posts</h2>
              </div>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>melody</h3>
            <div class="piano-keys">
              <div class="piano-key white-key" data-note="C4">C</div>
              <div class="piano-key black-key" data-note="Cs4">C#</div>
              <div class="piano-key white-key" data-note="D4">D</div>
              <div class="piano-key black-key" data-note="Ds4">D#</div>
              <div class="piano-key white-key" data-note="E4">E</div>
              <div class="piano-key white-key" data-note="F4">F</div>
              <div class="piano-key black-key" data-note="Fs4">F#</div>
              <div class="piano-key white-key" data-note="G4">G</div>
              <div class="piano-key black-key" data-note="Gs4">G#</div>
              <div class="piano-key white-key" data-note="A4">A</div>
              <div class="piano-key black-key" data-note="As4">A#</div>
              <div class="piano-key white-key" data-note="B4">B</div>
              <div class="piano-key white-key" data-note="C5">C</div>
              <div class="piano-key black-key" data-note="Cs5">C#</div>
              <div class="piano-key white-key" data-note="D5">D</div>
              <div class="piano-key black-key" data-note="Ds5">D#</div>
              <div class="piano-key white-key" data-note="E5">E</div>
            </div>
            <div class="audio-player">
              <audio id="piano-audio"></audio>
            </div>
          </div>
          <div class="side-card">
            <h3>Categories</h3>
            <div class="pill-list">
              {categories.map((category) => (
                <span>{category}</span>
              ))}
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-desc { color: var(--text-muted); margin: 0 0 1.25rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 1.5rem; }
  .piano-keys {
    height: 140px;
    background: 
      linear-gradient(180deg, #2F4F4F 0%, #1a1a1a 100%);
    border-radius: 16px;
    padding: 0.75rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 1px;
    position: relative;
    overflow-x: auto;
  }
  .piano-key {
    min-width: 22px;
    height: 90px;
    border-radius: 3px 3px 6px 6px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.1s ease;
    user-select: none;
  }
  .white-key {
    background: linear-gradient(to bottom, #fafafa, #e0e0e0);
    border: 1px solid #bbb;
    box-shadow: 0 3px 6px rgba(0,0,0,0.15);
    z-index: 1;
    color: #222;
  }
  .white-key:active, .white-key.active {
    background: linear-gradient(to bottom, #ffd700, #daa520);
    transform: translateY(3px);
  }
  .black-key {
    background: linear-gradient(to bottom, #1a1a1a, #000);
    color: transparent;
    height: 55px;
    min-width: 16px;
    margin: 0 -8px;
    border-radius: 0 0 4px 4px;
    z-index: 2;
  }
  .black-key:active, .black-key.active {
    background: linear-gradient(to bottom, #ff4500, #8b0000);
  }
  .audio-player { display: none; }
  @media (max-width: 768px) { .posts-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const noteFrequencies = {
    'C4': 261.63, 'Cs4': 277.18, 'D4': 293.66, 'Ds4': 311.13, 'E4': 329.63,
    'F4': 349.23, 'Fs4': 369.99, 'G4': 392.00, 'Gs4': 415.30, 'A4': 440.00, 'As4': 466.16, 'B4': 493.88,
    'C5': 523.25, 'Cs5': 554.37, 'D5': 587.33, 'Ds5': 622.25, 'E5': 659.25
  };
  
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  
  function playNote(frequency) {
    const oscillator = audioCtx.createOscillator();
    const gainNode = audioCtx.createGain();
    
    oscillator.type = 'triangle';
    oscillator.frequency.setValueAtTime(frequency, audioCtx.currentTime);
    
    gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.8);
    
    oscillator.connect(gainNode);
    gainNode.connect(audioCtx.destination);
    
    oscillator.start();
    oscillator.stop(audioCtx.currentTime + 0.8);
  }
  
  document.querySelectorAll('.piano-key').forEach(key => {
    key.addEventListener('click', () => {
      const note = key.dataset.note;
      if (note && noteFrequencies[note]) {
        key.classList.add('active');
        playNote(noteFrequencies[note]);
        setTimeout(() => key.classList.remove('active'), 200);
      }
    });
  });
</script>
