---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import galleryData from '../data/homepage-gallery.json';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const galleryItems = galleryData.images ?? [];
const rotatingLines = [
  '慢慢发光，渐渐成长',
  '一切都活了，都有着无限的本领，要做什么，就做什么',
  '相顾无言，唯有泪千行',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="shell home-shell">
      <section class="page-hero hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">personal signal</span>
          <h1 class="hero-title">Yunn 的 <span class="highlight">发呆网页</span></h1>
          <p class="hero-desc">请输入文本 ： ）</p>
          <div class="stat-row">
            <div class="stat-card">
              <strong>{posts.length}</strong>
              <span>recent notes</span>
            </div>
            <div class="stat-card">
              <strong>{galleryItems.length}</strong>
              <span>gallery frames</span>
            </div>
          </div>
        </div>
        <div class="hero-stage">
          <div class="floating-card intro-card">
            <span>Notebook</span>
            <strong>Words, traces, sparks.</strong>
          </div>
          <div class="floating-card orbit-card">
            <span>Current Mood</span>
            <strong id="rotating-line">{rotatingLines[0]}</strong>
          </div>
          <div class="mosaic">
            <div class="wide warm"></div>
            <div class="cool"></div>
            <div class="tall ember"></div>
            <div class="cool"></div>
            <div class="wide paper"></div>
            <div class="warm"></div>
          </div>
        </div>
      </section>

      <section class="page-grid">
        <div class="page-main-column">
          <section class="recent-posts card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>最新文章</h2>
              </div>
              <a href={withBase('blog/')} class="view-all">查看全部 →</a>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </section>

          <section class="gallery-section card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>my cherished picture</h2>
              </div>
            </div>

            {galleryItems.length > 0 ? (
              <div class="gallery-grid">
                {galleryItems.map((item) => (
                  <figure class="gallery-card">
                    <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
                    {(item.title || item.description) && (
                      <figcaption>
                        {item.title && <strong>{item.title}</strong>}
                        {item.description && <p>{item.description}</p>}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : (
              <div class="gallery-empty">
                <p>这里已经预留好了图片区。</p>
                <p>把图片放到 `public/images/homepage/`，再编辑 `src/data/homepage-gallery.json` 就能展示。</p>
              </div>
            )}
          </section>
        </div>

        <aside class="page-side-column">
          <div class="side-card live-card">
            <h3>此刻</h3>
            <strong id="live-clock">--:--:--</strong>
            <p id="live-date">----/--/--</p>
          </div>
          <div class="side-card">
            <h3>跳转入口</h3>
            <div class="pill-list">
              <a href={withBase('blog/')}>Blog</a>
              <a href={withBase('archive/')}>Archive</a>
              <a href={withBase('tags/')}>Tags</a>
              <a href={withBase('friends/')}>Friends</a>
            </div>
          </div>
          <div class="side-card train-scene">
            <h3>Good Mood</h3>
            <div class="train-container">
              <div class="sky-gradient"></div>
              <div class="stars">
                <div class="star star-1"></div>
                <div class="star star-2"></div>
                <div class="star star-3"></div>
              </div>
              <div class="moon"></div>
              <div class="mountains">
                <div class="mountain mt-1"></div>
                <div class="mountain mt-2"></div>
                <div class="mountain mt-3"></div>
              </div>
              <div class="trees">
                <div class="tree tree-1"></div>
                <div class="tree tree-2"></div>
                <div class="tree tree-3"></div>
                <div class="tree tree-4"></div>
              </div>
              <div class="water">
                <div class="wave wave-1"></div>
                <div class="wave wave-2"></div>
                <div class="wave wave-3"></div>
                <div class="wave wave-4"></div>
              </div>
              <div class="fireflies">
                <div class="firefly ff-1"></div>
                <div class="firefly ff-2"></div>
                <div class="firefly ff-3"></div>
              </div>
              <div class="shooting-star"></div>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script define:vars={{ rotatingLines }}>
      const lineNode = document.getElementById('rotating-line');
      const clockNode = document.getElementById('live-clock');
      const dateNode = document.getElementById('live-date');
      let lineIndex = 0;

      function updateClock() {
        const now = new Date();
        if (clockNode) {
          clockNode.textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
        }
        if (dateNode) {
          dateNode.textContent = now.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            weekday: 'short',
          });
        }
      }

      function rotateLine() {
        if (!lineNode) return;
        lineIndex = (lineIndex + 1) % rotatingLines.length;
        lineNode.textContent = rotatingLines[lineIndex];
      }

      updateClock();
      setInterval(updateClock, 1000);
      setInterval(rotateLine, 3200);
    </script>
  </body>
</html>

<style>
  .home-shell { gap: 1.75rem; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.9fr);
    gap: clamp(1.25rem, 2vw, 2rem);
    align-items: center;
    padding: clamp(1.75rem, 3vw, 3rem);
  }
  .hero-copy { display: flex; flex-direction: column; gap: 1.25rem; position: relative; z-index: 1; }
  .hero-title { font-size: clamp(2.8rem, 7vw, 5.8rem); margin: 0; line-height: 0.98; letter-spacing: 0.04em; }
  .highlight {
    display: inline-block;
    margin-left: 0.2em;
    background: linear-gradient(135deg, var(--primary), #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc { font-size: 1.1rem; color: var(--text-secondary); margin: 0; max-width: 40rem; }
  .hero-stage { position: relative; min-height: 420px; display: flex; align-items: center; justify-content: center; }
  .floating-card {
    position: absolute;
    padding: 1rem 1.1rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(14px);
    box-shadow: 0 16px 30px var(--shadow);
    max-width: 220px;
  }
  .floating-card span {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .floating-card strong { line-height: 1.5; font-size: 0.98rem; }
  .intro-card { top: 4%; left: 2%; transform: rotate(-4deg); }
  .orbit-card { right: 2%; bottom: 7%; transform: rotate(4deg); }
  .mosaic { width: min(100%, 520px); position: relative; z-index: 1; }
  .warm { background: linear-gradient(135deg, rgba(255, 214, 170, 0.86), rgba(255, 244, 230, 0.25)); }
  .cool { background: linear-gradient(135deg, rgba(153, 246, 228, 0.68), rgba(236, 253, 245, 0.18)); }
  .ember { background: radial-gradient(circle at 32% 24%, rgba(255, 255, 255, 0.5), transparent 24%), linear-gradient(135deg, rgba(234, 88, 12, 0.8), rgba(245, 158, 11, 0.28)); }
  .paper { background: linear-gradient(135deg, rgba(255, 255, 255, 0.7), rgba(255, 250, 240, 0.3)), repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(146, 121, 86, 0.09) 18px, rgba(146, 121, 86, 0.09) 19px); }
  .recent-posts, .gallery-section { display: flex; flex-direction: column; gap: 1.5rem; }
  .section-header h2 { margin: 0; font-size: 1.6rem; }
  .view-all { color: var(--primary); font-size: 0.95rem; text-decoration: none; transition: color 0.2s, transform 0.2s; }
  .view-all:hover { color: var(--primary-dark); transform: translateY(-1px); }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .gallery-card, .gallery-empty {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .gallery-card img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .gallery-card figcaption { padding: 1rem; }
  .gallery-card strong { display: block; margin-bottom: 0.4rem; font-size: 1rem; }
  .gallery-card p, .gallery-empty p { margin: 0; color: var(--text-secondary); line-height: 1.7; }
  .gallery-empty { padding: 2rem 1.5rem; border-style: dashed; text-align: center; }
  .live-card strong {
    display: block;
    font-size: 1.8rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .live-card p { margin: 0; }
  .train-scene {
    height: 200px;
    overflow: hidden;
    border-radius: 20px;
    position: relative;
    background: linear-gradient(180deg, #0c1445 0%, #1a237e 40%, #283593 70%, #1a237e 100%);
  }
  .train-container {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .sky-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0c1445 0%, #1a237e 35%, #3949ab 65%, #1a237e 100%);
  }
  .stars {
    position: absolute;
    inset: 0;
  }
  .star {
    position: absolute;
    background: #fff;
    border-radius: 50%;
    animation: twinkle 3s ease-in-out infinite;
  }
  .star-1 { width: 3px; height: 3px; top: 8%; left: 15%; animation-delay: 0s; }
  .star-2 { width: 2px; height: 2px; top: 12%; left: 45%; animation-delay: 0.5s; }
  .star-3 { width: 2px; height: 2px; top: 6%; left: 75%; animation-delay: 1s; }
  .moon {
    position: absolute;
    top: 15px;
    right: 25px;
    width: 36px;
    height: 36px;
    background: radial-gradient(circle at 30% 30%, #fffde7, #ffd54f);
    border-radius: 50%;
    box-shadow: 0 0 40px rgba(255, 213, 79, 0.6), 0 0 80px rgba(255, 213, 79, 0.3);
    animation: moonGlow 4s ease-in-out infinite;
  }
  .mountains {
    position: absolute;
    bottom: 55px;
    width: 100%;
    height: 80px;
  }
  .mountain {
    position: absolute;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
  }
  .mt-1 { left: -10%; border-width: 0 90px 70px 90px; border-color: transparent transparent #1b5e20 transparent; opacity: 0.85; }
  .mt-2 { left: 25%; border-width: 0 70px 55px 70px; border-color: transparent transparent #2e7d32 transparent; }
  .mt-3 { right: -5%; border-width: 0 80px 60px 80px; border-color: transparent transparent #1b5e20 transparent; opacity: 0.9; }
  .trees {
    position: absolute;
    bottom: 35px;
    width: 100%;
  }
  .tree {
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 12px 28px 12px;
    border-color: transparent transparent #1b5e20 transparent;
  }
  .tree-1 { left: 8%; }
  .tree-2 { left: 25%; border-width: 0 10px 22px 10px; }
  .tree-3 { left: 55%; border-width: 0 14px 32px 14px; }
  .tree-4 { left: 78%; border-width: 0 8px 18px 8px; }
  .water {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 40px;
    background: linear-gradient(180deg, #0d47a1 0%, #1565c0 50%, #0d47a1 100%);
    overflow: hidden;
  }
  .wave {
    position: absolute;
    width: 200%;
    height: 100%;
    background: repeating-linear-gradient(90deg, transparent, transparent 20px, rgba(255,255,255,0.08) 20px, rgba(255,255,255,0.08) 40px);
    animation: waveMove 8s linear infinite;
  }
  .wave-1 { top: 0; animation-delay: 0s; }
  .wave-2 { top: 8px; opacity: 0.7; animation-delay: 1s; }
  .wave-3 { top: 16px; opacity: 0.5; animation-delay: 2s; }
  .wave-4 { top: 24px; opacity: 0.3; animation-delay: 3s; }
  .fireflies {
    position: absolute;
    inset: 0;
  }
  .firefly {
    position: absolute;
    width: 4px;
    height: 4px;
    background: #ffeb3b;
    border-radius: 50%;
    box-shadow: 0 0 8px #ffeb3b, 0 0 16px #ffeb3b;
    animation: fireflyMove 7s ease-in-out infinite;
  }
  .ff-1 { top: 45%; left: 20%; animation-delay: 0s; }
  .ff-2 { top: 55%; left: 50%; animation-delay: 2s; }
  .ff-3 { top: 40%; left: 75%; animation-delay: 4s; }
  .shooting-star {
    position: absolute;
    top: 10%;
    left: -10%;
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.9));
    transform: rotate(-25deg);
    animation: shootingStar 10s linear infinite;
    animation-delay: 5s;
    opacity: 0;
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }
  @keyframes moonGlow {
    0%, 100% { box-shadow: 0 0 40px rgba(255, 213, 79, 0.6), 0 0 80px rgba(255, 213, 79, 0.3); }
    50% { box-shadow: 0 0 50px rgba(255, 213, 79, 0.8), 0 0 100px rgba(255, 213, 79, 0.4); }
  }
  @keyframes waveMove {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes fireflyMove {
    0% { transform: translate(0, 0); opacity: 0; }
    25% { opacity: 1; }
    50% { transform: translate(20px, -15px); opacity: 0.8; }
    75% { opacity: 1; }
    100% { transform: translate(40px, 0); opacity: 0; }
  }
  @keyframes shootingStar {
    0% { left: -10%; opacity: 0; }
    10% { opacity: 1; }
    30% { opacity: 0; }
    100% { left: 110%; opacity: 0; }
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(15, 118, 110, 0.35); }
    100% { box-shadow: 0 0 0 10px rgba(15, 118, 110, 0); }
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: 340px; }
  }
  @media (max-width: 768px) {
    .hero-title { font-size: clamp(2.6rem, 12vw, 3.8rem); }
    .hero-desc { font-size: 1rem; }
    .posts-grid, .gallery-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: auto; padding-top: 6rem; }
    .floating-card { max-width: none; }
  }
</style>
