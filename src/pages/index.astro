---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import galleryData from '../data/homepage-gallery.json';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const galleryItems = galleryData.images ?? [];
const rotatingLines = [
  '慢慢发光，渐渐成长',
  '一切都活了，都有着无限的本领，要做什么，就做什么',
  '相顾无言，唯有泪千行',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="shell home-shell">
      <section class="page-hero hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">personal signal</span>
          <h1 class="hero-title">Yunn 的 <span class="highlight">发呆网页</span></h1>
          <p class="hero-desc">请输入文本 ： ）</p>
          <div class="stat-row">
            <div class="stat-card">
              <strong>{posts.length}</strong>
              <span>recent notes</span>
            </div>
            <div class="stat-card">
              <strong>{galleryItems.length}</strong>
              <span>gallery frames</span>
            </div>
          </div>
        </div>
        <div class="hero-stage">
          <div class="floating-card intro-card">
            <span>Notebook</span>
            <strong>Words, traces, sparks.</strong>
          </div>
          <div class="floating-card orbit-card">
            <span>Current Mood</span>
            <strong id="rotating-line">{rotatingLines[0]}</strong>
          </div>
          <div class="mosaic">
            <div class="wide warm"></div>
            <div class="cool"></div>
            <div class="tall ember"></div>
            <div class="cool"></div>
            <div class="wide paper"></div>
            <div class="warm"></div>
          </div>
        </div>
      </section>

      <section class="page-grid">
        <div class="page-main-column">
          <section class="recent-posts card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>最新文章</h2>
              </div>
              <a href={withBase('blog/')} class="view-all">查看全部 →</a>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </section>

          <section class="gallery-section card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>my cherished picture</h2>
              </div>
            </div>

            {galleryItems.length > 0 ? (
              <div class="gallery-grid">
                {galleryItems.map((item) => (
                  <figure class="gallery-card">
                    <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
                    {(item.title || item.description) && (
                      <figcaption>
                        {item.title && <strong>{item.title}</strong>}
                        {item.description && <p>{item.description}</p>}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : (
              <div class="gallery-empty">
                <p>这里已经预留好了图片区。</p>
                <p>把图片放到 `public/images/homepage/`，再编辑 `src/data/homepage-gallery.json` 就能展示。</p>
              </div>
            )}
          </section>
        </div>

        <aside class="page-side-column">
          <div class="side-card live-card">
            <h3>此刻</h3>
            <strong id="live-clock">--:--:--</strong>
            <p id="live-date">----/--/--</p>
          </div>
          <div class="side-card">
            <h3>跳转入口</h3>
            <div class="pill-list">
              <a href={withBase('blog/')}>Blog</a>
              <a href={withBase('archive/')}>Archive</a>
              <a href={withBase('tags/')}>Tags</a>
              <a href={withBase('friends/')}>Friends</a>
            </div>
          </div>
          <div class="side-card scene-3d">
            <h3>Good Mood</h3>
            <div class="scene-container">
              <div class="universe">
                <div class="sun-3d"></div>
                <div class="orbit-core">
                  <div class="earth-tilt">
                    <div class="earth">
                      <div class="ocean"></div>
                      <div class="continent c1"></div>
                      <div class="continent c2"></div>
                      <div class="continent c3"></div>
                      <div class="atmosphere"></div>
                    </div>
                  </div>
                </div>
                <div class="orbit orbit-1">
                  <div class="moon-orbit"></div>
                </div>
                <div class="orbit orbit-2">
                  <div class="satellite s1"></div>
                </div>
                <div class="orbit orbit-3">
                  <div class="satellite s2"></div>
                </div>
                <div class="stars-field">
                  <div class="star-particle" style="--x:10%; --y:15%; --z:50;"></div>
                  <div class="star-particle" style="--x:70%; --y:20%; --z:30;"></div>
                  <div class="star-particle" style="--x:30%; --y:70%; --z:40;"></div>
                  <div class="star-particle" style="--x:80%; --y:60%; --z:60;"></div>
                  <div class="star-particle" style="--x:50%; --y:40%; --z:20;"></div>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script define:vars={{ rotatingLines }}>
      const lineNode = document.getElementById('rotating-line');
      const clockNode = document.getElementById('live-clock');
      const dateNode = document.getElementById('live-date');
      let lineIndex = 0;

      function updateClock() {
        const now = new Date();
        if (clockNode) {
          clockNode.textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
        }
        if (dateNode) {
          dateNode.textContent = now.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            weekday: 'short',
          });
        }
      }

      function rotateLine() {
        if (!lineNode) return;
        lineIndex = (lineIndex + 1) % rotatingLines.length;
        lineNode.textContent = rotatingLines[lineIndex];
      }

      updateClock();
      setInterval(updateClock, 1000);
      setInterval(rotateLine, 3200);
    </script>
  </body>
</html>

<style>
  .home-shell { gap: 1.75rem; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.9fr);
    gap: clamp(1.25rem, 2vw, 2rem);
    align-items: center;
    padding: clamp(1.75rem, 3vw, 3rem);
  }
  .hero-copy { display: flex; flex-direction: column; gap: 1.25rem; position: relative; z-index: 1; }
  .hero-title { font-size: clamp(2.8rem, 7vw, 5.8rem); margin: 0; line-height: 0.98; letter-spacing: 0.04em; }
  .highlight {
    display: inline-block;
    margin-left: 0.2em;
    background: linear-gradient(135deg, var(--primary), #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc { font-size: 1.1rem; color: var(--text-secondary); margin: 0; max-width: 40rem; }
  .hero-stage { position: relative; min-height: 420px; display: flex; align-items: center; justify-content: center; }
  .floating-card {
    position: absolute;
    padding: 1rem 1.1rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(14px);
    box-shadow: 0 16px 30px var(--shadow);
    max-width: 220px;
  }
  .floating-card span {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .floating-card strong { line-height: 1.5; font-size: 0.98rem; }
  .intro-card { top: 4%; left: 2%; transform: rotate(-4deg); }
  .orbit-card { right: 2%; bottom: 7%; transform: rotate(4deg); }
  .mosaic { width: min(100%, 520px); position: relative; z-index: 1; }
  .warm { background: linear-gradient(135deg, rgba(255, 214, 170, 0.86), rgba(255, 244, 230, 0.25)); }
  .cool { background: linear-gradient(135deg, rgba(153, 246, 228, 0.68), rgba(236, 253, 245, 0.18)); }
  .ember { background: radial-gradient(circle at 32% 24%, rgba(255, 255, 255, 0.5), transparent 24%), linear-gradient(135deg, rgba(234, 88, 12, 0.8), rgba(245, 158, 11, 0.28)); }
  .paper { background: linear-gradient(135deg, rgba(255, 255, 255, 0.7), rgba(255, 250, 240, 0.3)), repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(146, 121, 86, 0.09) 18px, rgba(146, 121, 86, 0.09) 19px); }
  .recent-posts, .gallery-section { display: flex; flex-direction: column; gap: 1.5rem; }
  .section-header h2 { margin: 0; font-size: 1.6rem; }
  .view-all { color: var(--primary); font-size: 0.95rem; text-decoration: none; transition: color 0.2s, transform 0.2s; }
  .view-all:hover { color: var(--primary-dark); transform: translateY(-1px); }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .gallery-card, .gallery-empty {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .gallery-card img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .gallery-card figcaption { padding: 1rem; }
  .gallery-card strong { display: block; margin-bottom: 0.4rem; font-size: 1rem; }
  .gallery-card p, .gallery-empty p { margin: 0; color: var(--text-secondary); line-height: 1.7; }
  .gallery-empty { padding: 2rem 1.5rem; border-style: dashed; text-align: center; }
  .live-card strong {
    display: block;
    font-size: 1.8rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .live-card p { margin: 0; }
  .scene-3d {
    height: 240px;
    overflow: hidden;
    border-radius: 20px;
    position: relative;
    background: radial-gradient(ellipse at center bottom, #1a1a2e 0%, #0a0a1a 50%, #000 100%);
    perspective: 600px;
    transform-style: preserve-3d;
  }
  .scene-container {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: rotateX(45deg);
    transform-origin: center bottom;
  }
  .universe {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 180px;
    height: 180px;
    transform-style: preserve-3d;
    animation: systemOrbit 25s linear infinite;
  }
  .sun-3d {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    background: radial-gradient(circle, #fff7ed 0%, #fbbf24 40%, #f59e0b 80%, #ea580c 100%);
    border-radius: 50%;
    box-shadow: 
      0 0 30px #fbbf24,
      0 0 60px rgba(251, 191, 36, 0.5),
      0 0 100px rgba(251, 191, 36, 0.3),
      inset 0 0 20px rgba(255, 255, 255, 0.4);
    animation: sunPulse 3s ease-in-out infinite;
  }
  .orbit-core {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    transform-style: preserve-3d;
  }
  .earth-tilt {
    transform: rotateX(-20deg);
    transform-style: preserve-3d;
  }
  .earth {
    position: absolute;
    width: 28px;
    height: 28px;
    background: radial-gradient(circle at 30% 30%, #4fc3f7 0%, #0288d1 50%, #01579b 100%);
    border-radius: 50%;
    transform-style: preserve-3d;
    animation: earthSpin 4s linear infinite;
    box-shadow: 
      0 0 10px rgba(2, 136, 209, 0.6),
      inset -3px -3px 8px rgba(0, 0, 0, 0.3);
  }
  .ocean {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(135deg, transparent 40%, rgba(33, 150, 243, 0.3) 100%);
  }
  .continent {
    position: absolute;
    background: #4caf50;
    border-radius: 40% 60% 50% 40%;
    opacity: 0.85;
  }
  .c1 { width: 8px; height: 10px; top: 20%; left: 25%; }
  .c2 { width: 6px; height: 8px; top: 45%; left: 55%; }
  .c3 { width: 5px; height: 6px; top: 60%; left: 30%; }
  .atmosphere {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(129, 212, 250, 0.3), transparent 60%);
    animation: atmosphereGlow 2s ease-in-out infinite;
  }
  .orbit {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    transform: translate(-50%, -50%) rotateX(75deg);
  }
  .orbit-1 { width: 90px; height: 30px; animation: orbitSpin 8s linear infinite; }
  .orbit-2 { width: 130px; height: 43px; animation: orbitSpin 12s linear infinite reverse; }
  .orbit-3 { width: 170px; height: 57px; animation: orbitSpin 16s linear infinite; }
  .moon-orbit {
    position: absolute;
    width: 8px;
    height: 8px;
    background: radial-gradient(circle, #fff9c4, #ffe082);
    border-radius: 50%;
    top: -4px;
    left: -4px;
    box-shadow: 0 0 8px rgba(255, 252, 224, 0.8);
  }
  .satellite {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .s1 {
    background: radial-gradient(circle, #ef5350, #c62828);
    box-shadow: 0 0 10px rgba(239, 83, 80, 0.8);
    top: -3px;
  }
  .s2 {
    background: radial-gradient(circle, #ab47bc, #7b1fa2);
    box-shadow: 0 0 10px rgba(171, 71, 188, 0.8);
    top: -3px;
  }
  .stars-field {
    position: absolute;
    inset: -100px;
    transform-style: preserve-3d;
  }
  .star-particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #fff;
    border-radius: 50%;
    left: var(--x);
    top: var(--y);
    transform: translateZ(var(--z));
    box-shadow: 0 0 6px #fff;
    animation: starTwinkle 2s ease-in-out infinite;
  }
  @keyframes systemOrbit {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes sunPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.08); }
  }
  @keyframes earthSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes atmosphereGlow {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }
  @keyframes orbitSpin {
    0% { transform: translate(-50%, -50%) rotateX(75deg) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotateX(75deg) rotate(360deg); }
  }
  @keyframes starTwinkle {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
  @keyframes cometTail {
    0% { transform: translateX(-150px) scale(0.5); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 0.8; }
    100% { transform: translateX(200px) scale(0.2); opacity: 0; }
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(15, 118, 110, 0.35); }
    100% { box-shadow: 0 0 0 10px rgba(15, 118, 110, 0); }
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: 340px; }
  }
  @media (max-width: 768px) {
    .hero-title { font-size: clamp(2.6rem, 12vw, 3.8rem); }
    .hero-desc { font-size: 1rem; }
    .posts-grid, .gallery-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: auto; padding-top: 6rem; }
    .floating-card { max-width: none; }
  }
</style>
