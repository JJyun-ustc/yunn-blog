---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import galleryData from '../data/homepage-gallery.json';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const galleryItems = galleryData.images ?? [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1 class="hero-title">芠芸的<span class="highlight">发癫网页</span></h1>
        <p class="hero-desc">记录点滴，分享随笔</p>
      </section>

      <section class="recent-posts">
        <div class="section-header">
          <h2>最新文章</h2>
          <a href={withBase('blog/')} class="view-all">查看全部 →</a>
        </div>
        <div class="posts-grid">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </section>

      <section class="gallery-section">
        <div class="section-header">
          <div>
            <h2>图片展示窗口</h2>
            <p class="section-subtitle">把图片放进固定目录，再改一次展示数据，就能更新首页图片区。</p>
          </div>
          <span class="manage-hint">推荐目录：`public/images/homepage/`</span>
        </div>

        {galleryItems.length > 0 ? (
          <div class="gallery-grid">
            {galleryItems.map((item) => (
              <figure class="gallery-card">
                <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
                {(item.title || item.description) && (
                  <figcaption>
                    {item.title && <strong>{item.title}</strong>}
                    {item.description && <p>{item.description}</p>}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        ) : (
          <div class="gallery-empty">
            <p>这里已经预留好了图片展示区。</p>
            <p>把图片放到 `public/images/homepage/`，再编辑 `src/data/homepage-gallery.json` 就能展示。</p>
          </div>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    margin-bottom: 1rem;
    line-height: 1.1;
    letter-spacing: 0.04em;
  }

  .highlight {
    display: inline-block;
    margin-left: 0.2em;
    background: linear-gradient(135deg, #e8572a, #ffb703);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .recent-posts,
  .gallery-section {
    margin: 3rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.5rem;
  }

  .section-subtitle {
    margin: 0.35rem 0 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .view-all {
    color: var(--primary);
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
  }

  .view-all:hover {
    color: var(--primary-dark);
    transform: translateY(-1px);
  }

  .manage-hint {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .gallery-card,
  .gallery-empty {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 30px var(--shadow);
  }

  .gallery-card img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .gallery-card figcaption {
    padding: 1rem;
  }

  .gallery-card strong {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 1rem;
  }

  .gallery-card p,
  .gallery-empty p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .gallery-empty {
    padding: 2rem 1.5rem;
    border-style: dashed;
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 3rem;
    }

    .hero-desc {
      font-size: 1rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .posts-grid,
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
