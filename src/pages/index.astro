---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import galleryData from '../data/homepage-gallery.json';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const galleryItems = galleryData.images ?? [];
const rotatingLines = [
  '慢慢发光，渐渐成长',
  '一切都活了，都有着无限的本领，要做什么，就做什么',
  '相顾无言，唯有泪千行',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="shell home-shell">
      <section class="page-hero hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">personal signal</span>
          <h1 class="hero-title">Yunn 的 <span class="highlight">发呆网页</span></h1>
          <p class="hero-desc">请输入文本 ： ）</p>
          <div class="stat-row">
            <div class="stat-card">
              <strong>{posts.length}</strong>
              <span>recent notes</span>
            </div>
            <div class="stat-card">
              <strong>{galleryItems.length}</strong>
              <span>gallery frames</span>
            </div>
          </div>
        </div>
        <div class="hero-stage">
          <div class="floating-card intro-card">
            <span>Notebook</span>
            <strong>Words, traces, sparks.</strong>
          </div>
          <div class="floating-card orbit-card">
            <span>Current Mood</span>
            <strong id="rotating-line">{rotatingLines[0]}</strong>
          </div>
          <div class="mosaic">
            <div class="wide warm"></div>
            <div class="cool"></div>
            <div class="tall ember"></div>
            <div class="cool"></div>
            <div class="wide paper"></div>
            <div class="warm"></div>
          </div>
        </div>
      </section>

      <section class="page-grid">
        <div class="page-main-column">
          <section class="recent-posts card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>最新文章</h2>
              </div>
              <a href={withBase('blog/')} class="view-all">查看全部 →</a>
            </div>
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </section>

          <section class="gallery-section card-surface">
            <div class="section-heading-block section-header">
              <div>
                <h2>my cherished picture</h2>
              </div>
            </div>

            {galleryItems.length > 0 ? (
              <div class="gallery-grid">
                {galleryItems.map((item) => (
                  <figure class="gallery-card">
                    <img src={withBase(item.image)} alt={item.alt} loading="lazy" />
                    {(item.title || item.description) && (
                      <figcaption>
                        {item.title && <strong>{item.title}</strong>}
                        {item.description && <p>{item.description}</p>}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : (
              <div class="gallery-empty">
                <p>这里已经预留好了图片区。</p>
                <p>把图片放到 `public/images/homepage/`，再编辑 `src/data/homepage-gallery.json` 就能展示。</p>
              </div>
            )}
          </section>
        </div>

        <aside class="page-side-column">
          <div class="side-card live-card">
            <h3>此刻</h3>
            <strong id="live-clock">--:--:--</strong>
            <p id="live-date">----/--/--</p>
          </div>
          <div class="side-card">
            <h3>跳转入口</h3>
            <div class="pill-list">
              <a href={withBase('blog/')}>Blog</a>
              <a href={withBase('archive/')}>Archive</a>
              <a href={withBase('tags/')}>Tags</a>
              <a href={withBase('friends/')}>Friends</a>
            </div>
          </div>
          <div class="side-card scene-3d">
            <h3 class="glow-title">Good Mood</h3>
            <div class="nature-scene">
              <div class="sky"></div>
              <div class="sun-rays">
                <div class="ray ray-1"></div>
                <div class="ray ray-2"></div>
                <div class="ray ray-3"></div>
              </div>
              <div class="sun-glow"></div>
              <div class="clouds-3d">
                <div class="cloud-3d cld-1"></div>
                <div class="cloud-3d cld-2"></div>
                <div class="cloud-3d cld-3"></div>
              </div>
              <div class="mountains-3d">
                <div class="peak peak-1"></div>
                <div class="peak peak-2"></div>
                <div class="peak peak-3"></div>
              </div>
              <div class="forest">
                <div class="tree-3d t1">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
                <div class="tree-3d t2">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
                <div class="tree-3d t3">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
                <div class="tree-3d t4">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
                <div class="tree-3d t5">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
                <div class="tree-3d t6">
                  <div class="trunk"></div>
                  <div class="foliage"></div>
                </div>
              </div>
              <div class="ground"></div>
              <div class="particles">
                <div class="particle p1"></div>
                <div class="particle p2"></div>
                <div class="particle p3"></div>
                <div class="particle p4"></div>
                <div class="particle p5"></div>
              </div>
              <div class="birds">
                <div class="bird b1"></div>
                <div class="bird b2"></div>
                <div class="bird b3"></div>
              </div>
              <div class="fireflies-3d">
                <div class="fly f1"></div>
                <div class="fly f2"></div>
                <div class="fly f3"></div>
                <div class="fly f4"></div>
              </div>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script define:vars={{ rotatingLines }}>
      const lineNode = document.getElementById('rotating-line');
      const clockNode = document.getElementById('live-clock');
      const dateNode = document.getElementById('live-date');
      let lineIndex = 0;

      function updateClock() {
        const now = new Date();
        if (clockNode) {
          clockNode.textContent = now.toLocaleTimeString('zh-CN', { hour12: false });
        }
        if (dateNode) {
          dateNode.textContent = now.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            weekday: 'short',
          });
        }
      }

      function rotateLine() {
        if (!lineNode) return;
        lineIndex = (lineIndex + 1) % rotatingLines.length;
        lineNode.textContent = rotatingLines[lineIndex];
      }

      updateClock();
      setInterval(updateClock, 1000);
      setInterval(rotateLine, 3200);
    </script>
  </body>
</html>

<style>
  .home-shell { gap: 1.75rem; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.9fr);
    gap: clamp(1.25rem, 2vw, 2rem);
    align-items: center;
    padding: clamp(1.75rem, 3vw, 3rem);
  }
  .hero-copy { display: flex; flex-direction: column; gap: 1.25rem; position: relative; z-index: 1; }
  .hero-title { font-size: clamp(2.8rem, 7vw, 5.8rem); margin: 0; line-height: 0.98; letter-spacing: 0.04em; }
  .highlight {
    display: inline-block;
    margin-left: 0.2em;
    background: linear-gradient(135deg, var(--primary), #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc { font-size: 1.1rem; color: var(--text-secondary); margin: 0; max-width: 40rem; }
  .hero-stage { position: relative; min-height: 420px; display: flex; align-items: center; justify-content: center; }
  .floating-card {
    position: absolute;
    padding: 1rem 1.1rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(14px);
    box-shadow: 0 16px 30px var(--shadow);
    max-width: 220px;
  }
  .floating-card span {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .floating-card strong { line-height: 1.5; font-size: 0.98rem; }
  .intro-card { top: 4%; left: 2%; transform: rotate(-4deg); }
  .orbit-card { right: 2%; bottom: 7%; transform: rotate(4deg); }
  .mosaic { width: min(100%, 520px); position: relative; z-index: 1; }
  .warm { background: linear-gradient(135deg, rgba(255, 214, 170, 0.86), rgba(255, 244, 230, 0.25)); }
  .cool { background: linear-gradient(135deg, rgba(153, 246, 228, 0.68), rgba(236, 253, 245, 0.18)); }
  .ember { background: radial-gradient(circle at 32% 24%, rgba(255, 255, 255, 0.5), transparent 24%), linear-gradient(135deg, rgba(234, 88, 12, 0.8), rgba(245, 158, 11, 0.28)); }
  .paper { background: linear-gradient(135deg, rgba(255, 255, 255, 0.7), rgba(255, 250, 240, 0.3)), repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(146, 121, 86, 0.09) 18px, rgba(146, 121, 86, 0.09) 19px); }
  .recent-posts, .gallery-section { display: flex; flex-direction: column; gap: 1.5rem; }
  .section-header h2 { margin: 0; font-size: 1.6rem; }
  .view-all { color: var(--primary); font-size: 0.95rem; text-decoration: none; transition: color 0.2s, transform 0.2s; }
  .view-all:hover { color: var(--primary-dark); transform: translateY(-1px); }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .gallery-card, .gallery-empty {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .gallery-card img { display: block; width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .gallery-card figcaption { padding: 1rem; }
  .gallery-card strong { display: block; margin-bottom: 0.4rem; font-size: 1rem; }
  .gallery-card p, .gallery-empty p { margin: 0; color: var(--text-secondary); line-height: 1.7; }
  .gallery-empty { padding: 2rem 1.5rem; border-style: dashed; text-align: center; }
  .live-card strong {
    display: block;
    font-size: 1.8rem;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .live-card p { margin: 0; }
  .scene-3d {
    height: 260px;
    overflow: hidden;
    border-radius: 20px;
    position: relative;
    background: linear-gradient(180deg, #87ceeb 0%, #e0f7fa 30%, #b8e994 60%, #78c95f 100%);
    transform-style: preserve-3d;
  }
  .glow-title {
    position: relative;
    color: #ff6f00;
    text-shadow: 
      0 0 10px #ffb300,
      0 0 20px #ff8f00,
      0 0 30px #ff6f00,
      0 0 40px #ffca28;
    animation: titleGlow 2s ease-in-out infinite alternate;
  }
  @keyframes titleGlow {
    0% { text-shadow: 0 0 10px #ffb300, 0 0 20px #ff8f00, 0 0 30px #ff6f00, 0 0 40px #ffca28; }
    100% { text-shadow: 0 0 15px #ffca28, 0 0 30px #ffb300, 0 0 45px #ff8f00, 0 0 60px #ff6f00; }
  }
  .nature-scene {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }
  .sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #87ceeb 0%, #b3e5fc 50%, #e1f5fe 100%);
  }
  .sun-rays {
    position: absolute;
    top: 8%;
    right: 15%;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
  }
  .ray {
    position: absolute;
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, rgba(255, 193, 7, 0.9), transparent);
    top: 50%;
    left: 50%;
    transform-origin: left center;
    animation: rayRotate 8s linear infinite;
  }
  .ray-1 { transform: translate(-50%, -50%) rotate(0deg); }
  .ray-2 { transform: translate(-50%, -50%) rotate(60deg); animation-delay: -2s; }
  .ray-3 { transform: translate(-50%, -50%) rotate(120deg); animation-delay: -4s; }
  .sun-glow {
    position: absolute;
    top: 8%;
    right: 15%;
    width: 50px;
    height: 50px;
    background: radial-gradient(circle, #ffeb3b 0%, #ffc107 50%, transparent 70%);
    border-radius: 50%;
    box-shadow: 0 0 40px #ffc107, 0 0 80px rgba(255, 193, 7, 0.5);
    animation: sunPulse 4s ease-in-out infinite;
  }
  .clouds-3d {
    position: absolute;
    inset: 0;
  }
  .cloud-3d {
    position: absolute;
    background: white;
    border-radius: 50px;
    opacity: 0.9;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.1));
  }
  .cld-1 {
    width: 70px;
    height: 25px;
    top: 15%;
    left: 10%;
    animation: cloudFloat 18s linear infinite;
  }
  .cld-2 {
    width: 50px;
    height: 20px;
    top: 20%;
    left: 45%;
    animation: cloudFloat 22s linear infinite 3s;
  }
  .cld-3 {
    width: 55px;
    height: 22px;
    top: 12%;
    left: 70%;
    animation: cloudFloat 20s linear infinite 6s;
  }
  .mountains-3d {
    position: absolute;
    bottom: 45%;
    left: 0;
    right: 0;
    height: 80px;
  }
  .peak {
    position: absolute;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
  }
  .peak-1 {
    left: -5%;
    border-width: 0 100px 90px 100px;
    border-color: transparent transparent #5d7a48 transparent;
  }
  .peak-2 {
    left: 15%;
    border-width: 0 80px 70px 80px;
    border-color: transparent transparent #6b8e5a transparent;
  }
  .peak-3 {
    right: -5%;
    border-width: 0 90px 80px 90px;
    border-color: transparent transparent #5d7a48 transparent;
  }
  .forest {
    position: absolute;
    bottom: 25%;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-around;
    transform-style: preserve-3d;
  }
  .tree-3d {
    position: relative;
    width: 20px;
    transform-style: preserve-3d;
  }
  .tree-3d .trunk {
    width: 6px;
    height: 25px;
    background: linear-gradient(180deg, #8d6e63, #5d4037);
    margin: 0 auto;
    border-radius: 2px;
  }
  .tree-3d .foliage {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 18px 30px 18px;
    border-color: transparent transparent #2e7d32 transparent;
  }
  .t1 { transform: scale(1.2) translateZ(10px); }
  .t2 { transform: scale(0.9) translateZ(-5px); }
  .t3 { transform: scale(1.1) translateZ(8px); }
  .t4 { transform: scale(0.85) translateZ(-8px); }
  .t5 { transform: scale(1) translateZ(0px); }
  .t6 { transform: scale(0.95) translateZ(5px); }
  .ground {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 25%;
    background: linear-gradient(180deg, #8bc34a 0%, #689f38 100%);
  }
  .particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    animation: particleFloat 6s ease-in-out infinite;
  }
  .p1 { left: 10%; top: 30%; background: #fff; animation-delay: 0s; }
  .p2 { left: 25%; top: 45%; background: #ffcc80; animation-delay: 1s; }
  .p3 { left: 50%; top: 35%; background: #fff; animation-delay: 2s; }
  .p4 { left: 70%; top: 50%; background: #ffcc80; animation-delay: 3s; }
  .p5 { left: 85%; top: 40%; background: #fff; animation-delay: 4s; }
  .birds {
    position: absolute;
    top: 25%;
    width: 100%;
  }
  .bird {
    position: absolute;
    width: 12px;
    height: 4px;
    background: #333;
    border-radius: 50%;
    animation: birdFly 15s linear infinite;
  }
  .bird::before, .bird::after {
    content: '';
    position: absolute;
    width: 8px;
    height: 6px;
    border: 2px solid #333;
    border-radius: 50%;
    top: -3px;
  }
  .bird::before { left: -6px; border-right: none; border-radius: 50% 0 0 50%; }
  .bird::after { right: -6px; border-left: none; border-radius: 0 50% 50% 0; }
  .b1 { left: 10%; animation-delay: 0s; }
  .b2 { left: 40%; animation-delay: 5s; }
  .b3 { left: 70%; animation-delay: 10s; }
  .fireflies-3d {
    position: absolute;
    inset: 0;
  }
  .fly {
    position: absolute;
    width: 5px;
    height: 5px;
    background: #ffeb3b;
    border-radius: 50%;
    box-shadow: 0 0 10px #ffeb3b, 0 0 20px #ffc107;
    animation: fireflyMove 5s ease-in-out infinite;
  }
  .f1 { left: 15%; bottom: 35%; animation-delay: 0s; }
  .f2 { left: 40%; bottom: 45%; animation-delay: 1.5s; }
  .f3 { left: 60%; bottom: 30%; animation-delay: 2.5s; }
  .f4 { left: 80%; bottom: 40%; animation-delay: 3.5s; }
  @keyframes rayRotate {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes sunPulse {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  @keyframes cloudFloat {
    0% { transform: translateX(0); }
    100% { transform: translateX(200px); }
  }
  @keyframes particleFloat {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    50% { transform: translateY(-30px) rotate(180deg); opacity: 1; }
    100% { transform: translateY(0) rotate(360deg); opacity: 0.6; }
  }
  @keyframes birdFly {
    0% { transform: translateX(-100px); }
    100% { transform: translateX(300px); }
  }
  @keyframes fireflyMove {
    0% { transform: translate(0, 0); opacity: 0.3; }
    25% { opacity: 1; }
    50% { transform: translate(20px, -20px); opacity: 0.8; }
    75% { opacity: 1; }
    100% { transform: translate(40px, 0); opacity: 0.3; }
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(15, 118, 110, 0.35); }
    100% { box-shadow: 0 0 0 10px rgba(15, 118, 110, 0); }
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: 340px; }
  }
  @media (max-width: 768px) {
    .hero-title { font-size: clamp(2.6rem, 12vw, 3.8rem); }
    .hero-desc { font-size: 1rem; }
    .posts-grid, .gallery-grid { grid-template-columns: 1fr; }
    .hero-stage { min-height: auto; padding-top: 6rem; }
    .floating-card { max-width: none; }
  }
</style>
