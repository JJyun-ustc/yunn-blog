---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();

  posts.forEach((post) => {
    (post.data.tags || []).forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => (post.data.tags || []).includes(tag) && !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${tag} - ${SITE_TITLE}`} description={`标签：${tag}`} />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <nav class="breadcrumb">
          <a href={withBase('tags/')}>标签</a>
          <span>/</span>
          <span>{tag}</span>
        </nav>
        <h1>#{tag}</h1>
        <p class="page-desc">共 {posts.length} 篇文章</p>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>Current Tag</h3>
            <div class="beat-bars">
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
              <div class="bar"></div>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .breadcrumb { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; }
  .breadcrumb a { color: var(--text-muted); }
  .page-desc { color: var(--text-muted); margin: 0; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .beat-bars { display: flex; align-items: flex-end; justify-content: center; gap: 6px; height: 80px; padding: 1rem 0; }
  .bar {
    width: 12px;
    border-radius: 6px;
    animation: beat 0.8s ease-in-out infinite;
  }
  .bar:nth-child(1) { height: 35%; background: linear-gradient(to top, #f97316, #fbbf24); animation-delay: 0s; }
  .bar:nth-child(2) { height: 65%; background: linear-gradient(to top, #ec4899, #f472b6); animation-delay: 0.1s; }
  .bar:nth-child(3) { height: 50%; background: linear-gradient(to top, #8b5cf6, #a78bfa); animation-delay: 0.2s; }
  .bar:nth-child(4) { height: 80%; background: linear-gradient(to top, #06b6d4, #22d3ee); animation-delay: 0.3s; }
  .bar:nth-child(5) { height: 45%; background: linear-gradient(to top, #10b981, #34d399); animation-delay: 0.4s; }
  @keyframes beat {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }
</style>
