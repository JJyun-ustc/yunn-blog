---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { SITE_TITLE } from '../../consts';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();

  posts.forEach((post) => {
    (post.data.tags || []).forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => (post.data.tags || []).includes(tag) && !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${tag} - ${SITE_TITLE}`} description={`标签：${tag}`} />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <nav class="breadcrumb">
          <a href={withBase('tags/')}>标签</a>
          <span>/</span>
          <span>{tag}</span>
        </nav>
        <h1>#{tag}</h1>
        <p class="page-desc">共 {posts.length} 篇文章</p>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="posts-grid">
              {posts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>音乐波形</h3>
            <div class="music-wave">
              <svg viewBox="0 0 300 100" class="wave-svg">
                <path class="wave-path" d="M0,50 Q50,20 100,50 T200,50 T300,50" />
              </svg>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .breadcrumb { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; }
  .breadcrumb a { color: var(--text-muted); }
  .page-desc { color: var(--text-muted); margin: 0; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .music-wave {
    height: 120px;
    background: 
      radial-gradient(ellipse at center, rgba(135, 206, 250, 0.2), transparent 60%),
      linear-gradient(135deg, rgba(25, 25, 112, 0.95), rgba(70, 130, 180, 0.85));
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wave-svg {
    width: 100%;
    height: 100%;
  }
  .wave-path {
    fill: none;
    stroke: rgba(135, 206, 250, 0.8);
    stroke-width: 3;
    filter: drop-shadow(0 0 8px rgba(135, 206, 250, 0.6));
    animation: waveAnimation 3s ease-in-out infinite;
  }
  @keyframes waveAnimation {
    0% { d: path("M0,50 Q50,20 100,50 T200,50 T300,50"); }
    25% { d: path("M0,50 Q50,80 100,50 T200,50 T300,50"); }
    50% { d: path("M0,50 Q50,30 100,50 T200,50 T300,50"); }
    75% { d: path("M0,50 Q50,70 100,50 T200,50 T300,50"); }
    100% { d: path("M0,50 Q50,20 100,50 T200,50 T300,50"); }
  }
</style>
