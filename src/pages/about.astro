---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const personalInfo = {
  name: '芠芸',
  bio: '学习，反思，留痕，向上',
  avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=wenyun',
  github: 'https://github.com/JJyun-ustc',
};

const skills = [
  { name: 'python/C', color: '#ff6b35' },
  { name: '控制理论', color: '#2a9d8f' },
  { name: 'matlab', color: '#577590' },
  { name: 'ViT', color: '#ffb703' },
  { name: 'pornhub', color: '#d62828' },
];

const timeline = [
  {
    year: '2023',
    title: '中国科学技术大学 10系',
    description: '继续积累，继续向上。',
  },
  {
    year: '2026',
    title: '未知，待续',
    description: '故事还没写完。',
  },
];

const skillStops = skills
  .map((skill, index) => {
    const start = index * (100 / skills.length);
    const end = (index + 1) * (100 / skills.length);
    return `${skill.color} ${start}% ${end}%`;
  })
  .join(', ');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`关于 - ${SITE_TITLE}`} description="关于博客" />
  </head>
  <body>
    <Header />
    <main class="about-page">
      <div class="about-header">
        <div class="avatar">
          <img src={personalInfo.avatar} alt={personalInfo.name} />
        </div>
        <h1>{personalInfo.name}</h1>
        <p class="bio">{personalInfo.bio}</p>
        <div class="social-links">
          <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <div class="about-content">
        <section class="about-section">
          <h2>关于博客</h2>
          <p>{personalInfo.bio}</p>
        </section>

        <section class="about-section">
          <h2>技能</h2>
          <div class="skill-chart-wrap">
            <div class="skill-chart" style={`background: conic-gradient(${skillStops});`}>
              <div class="skill-chart-hole"></div>
            </div>
            {skills.map((skill, index) => {
              const angle = (360 / skills.length) * index - 90 + 36;
              const radians = (angle * Math.PI) / 180;
              const x = Math.cos(radians);
              const y = Math.sin(radians);
              const left = 50 + x * 44;
              const top = 50 + y * 44;
              const justify = x >= 0 ? 'flex-start' : 'flex-end';
              const textAlign = x >= 0 ? 'left' : 'right';

              return (
                <div
                  class="skill-label"
                  style={`left:${left}%; top:${top}%; --color:${skill.color}; justify-content:${justify}; text-align:${textAlign};`}
                >
                  {x < 0 && <span class="skill-name">{skill.name}</span>}
                  <span class="skill-dot"></span>
                  <span class="skill-line"></span>
                  {x >= 0 && <span class="skill-name">{skill.name}</span>}
                </div>
              );
            })}
          </div>
        </section>

        <section class="about-section">
          <h2>经历</h2>
          <div class="timeline">
            {timeline.map((item) => (
              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <span class="timeline-year">{item.year}</span>
                  <h3 class="timeline-title">{item.title}</h3>
                  <p class="timeline-desc">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="about-section">
          <h2>联系方式</h2>
          <div class="contact-links">
            <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              GitHub
            </a>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .about-header {
    text-align: center;
    padding: 3rem 0;
  }

  .avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    padding: 3px;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--card-bg);
  }

  .about-header h1 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
  }

  .bio {
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .social-link:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .about-section {
    margin-bottom: 2.8rem;
  }

  .about-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .skill-chart-wrap {
    position: relative;
    width: min(100%, 540px);
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .skill-chart {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    box-shadow: 0 14px 30px var(--shadow);
  }

  .skill-chart-hole {
    position: absolute;
    inset: 24%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 50%;
  }

  .skill-label {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 180px;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .skill-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--color) 20%, transparent);
    flex-shrink: 0;
  }

  .skill-line {
    width: 34px;
    height: 2px;
    background: var(--color);
    position: relative;
    flex-shrink: 0;
  }

  .skill-line::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    width: 8px;
    height: 8px;
    border-top: 2px solid var(--color);
    border-right: 2px solid var(--color);
    transform: translateY(-50%) rotate(45deg);
  }

  .skill-name {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--primary);
    border: 3px solid var(--card-bg);
  }

  .timeline-content {
    padding-left: 0.5rem;
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .timeline-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .timeline-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .contact-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .contact-link:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px var(--shadow);
  }

  @media (max-width: 768px) {
    .about-header {
      padding: 2rem 0;
    }

    .avatar {
      width: 100px;
      height: 100px;
    }

    .about-header h1 {
      font-size: 1.5rem;
    }

    .skill-chart-wrap {
      width: 100%;
      min-height: 420px;
    }

    .skill-chart {
      inset: 22%;
    }

    .skill-label {
      width: 124px;
      gap: 0.35rem;
    }

    .skill-line {
      width: 20px;
    }

    .skill-name {
      font-size: 0.82rem;
    }
  }
</style>
