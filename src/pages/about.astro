---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const personalInfo = {
  name: '芠芸',
  bio: '学习，反思，留痕，向上',
  avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=wenyun',
  github: 'https://github.com/JJyun-ustc',
};

const skills = [
  { name: 'python/C', color: '#5b8cff' },
  { name: '控制理论', color: '#23f2ff' },
  { name: 'matlab', color: '#ff5db1' },
  { name: 'ViT', color: '#a6ff47' },
  { name: 'pornhub', color: '#ff8a1f' },
];

const timeline = [
  {
    year: '2023',
    title: '中国科学技术大学 10系',
    description: 'gpa-4.3++',
  },
  {
    year: '2026',
    title: '未知，待续',
    description: '故事还没写完。',
  },
];

const skillStops = skills
  .map((skill, index) => {
    const start = index * (100 / skills.length);
    const end = (index + 1) * (100 / skills.length);
    return `${skill.color} ${start}% ${end}%`;
  })
  .join(', ');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`关于 - ${SITE_TITLE}`} description="关于博客" />
  </head>
  <body>
    <Header />
    <main class="about-page">
      <div class="about-header">
        <div class="avatar">
          <img src={personalInfo.avatar} alt={personalInfo.name} />
        </div>
        <h1>{personalInfo.name}</h1>
        <p class="bio">{personalInfo.bio}</p>
        <div class="social-links">
          <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <div class="about-content">
        <section class="about-section">
          <h2>关于博客</h2>
          <p>请输入文本 ： ）</p>
        </section>

        <section class="about-section">
          <h2>技能</h2>
          <div class="skill-panel">
            <div class="skill-grid"></div>
            <div class="skill-glow"></div>
            <div class="skill-chart-wrap">
              <div class="skill-ring outer-ring"></div>
              <div class="skill-ring middle-ring"></div>
              <div class="scan-ring"></div>
              <div class="skill-chart" style={`background: conic-gradient(${skillStops});`}>
                <div class="skill-chart-hole">
                  <span class="core-title">SKILL</span>
                  <span class="core-subtitle">SYSTEM</span>
                </div>
              </div>
              {skills.map((skill, index) => {
                const angle = (360 / skills.length) * index - 90 + 36;
                const radians = (angle * Math.PI) / 180;
                const x = Math.cos(radians);
                const y = Math.sin(radians);
                const left = 50 + x * 44;
                const top = 50 + y * 44;

                return (
                  <div
                    class="skill-label"
                    style={`left:${left}%; top:${top}%; --color:${skill.color};`}
                  >
                    <span class="skill-beacon"></span>
                    <span class="skill-name">{skill.name}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </section>

        <section class="about-section">
          <h2>经历</h2>
          <div class="timeline">
            {timeline.map((item) => (
              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <span class="timeline-year">{item.year}</span>
                  <h3 class="timeline-title">{item.title}</h3>
                  <p class="timeline-desc">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="about-section">
          <h2>联系方式</h2>
          <div class="contact-links">
            <a href={personalInfo.github} target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              GitHub
            </a>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .about-header {
    text-align: center;
    padding: 3rem 0;
  }

  .avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, #071a3d, #3a0b77);
    padding: 3px;
    box-shadow: 0 0 28px rgba(35, 242, 255, 0.22);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--card-bg);
  }

  .about-header h1 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
  }

  .bio {
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: linear-gradient(135deg, rgba(11, 20, 47, 0.9), rgba(38, 9, 73, 0.92));
    border: 1px solid rgba(91, 140, 255, 0.3);
    border-radius: 999px;
    color: #e8f2ff;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(15, 21, 51, 0.28);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .social-link:hover {
    border-color: #23f2ff;
    transform: translateY(-2px);
    box-shadow: 0 0 22px rgba(35, 242, 255, 0.22);
  }

  .about-section {
    margin-bottom: 2.8rem;
  }

  .about-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .skill-panel {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    padding: 2rem;
    background:
      radial-gradient(circle at 50% 50%, rgba(35, 242, 255, 0.18), transparent 28%),
      radial-gradient(circle at 18% 22%, rgba(255, 93, 177, 0.16), transparent 20%),
      linear-gradient(135deg, rgba(7, 16, 38, 0.96), rgba(19, 6, 48, 0.96));
    border: 1px solid rgba(91, 140, 255, 0.22);
    box-shadow: 0 30px 60px rgba(5, 10, 28, 0.35);
  }

  .skill-grid,
  .skill-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .skill-grid {
    background-image:
      linear-gradient(rgba(91, 140, 255, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(91, 140, 255, 0.12) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: radial-gradient(circle at center, black 42%, transparent 88%);
  }

  .skill-glow {
    background:
      radial-gradient(circle at center, rgba(35, 242, 255, 0.14), transparent 34%),
      radial-gradient(circle at center, rgba(166, 255, 71, 0.1), transparent 50%);
  }

  .skill-chart-wrap {
    position: relative;
    width: min(100%, 560px);
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .skill-ring,
  .scan-ring {
    position: absolute;
    border-radius: 50%;
  }

  .skill-ring {
    border: 1px solid rgba(91, 140, 255, 0.22);
  }

  .outer-ring {
    inset: 6%;
    box-shadow: 0 0 35px rgba(35, 242, 255, 0.08);
  }

  .middle-ring {
    inset: 14%;
    border-style: dashed;
    animation: orbit 18s linear infinite;
  }

  .scan-ring {
    inset: 2%;
    border: 1px solid rgba(35, 242, 255, 0.18);
    box-shadow: inset 0 0 24px rgba(35, 242, 255, 0.06);
  }

  .skill-chart {
    position: absolute;
    inset: 22%;
    border-radius: 50%;
    box-shadow:
      0 0 34px rgba(35, 242, 255, 0.18),
      0 0 68px rgba(91, 140, 255, 0.14);
  }

  .skill-chart::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .skill-chart-hole {
    position: absolute;
    inset: 24%;
    background:
      radial-gradient(circle at center, rgba(35, 242, 255, 0.08), transparent 60%),
      linear-gradient(135deg, rgba(6, 15, 35, 0.98), rgba(18, 5, 44, 0.98));
    border: 1px solid rgba(91, 140, 255, 0.22);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 0 24px rgba(35, 242, 255, 0.08);
  }

  .core-title,
  .core-subtitle {
    display: block;
    font-weight: 700;
    letter-spacing: 0.28em;
    color: #e7f2ff;
  }

  .core-title {
    font-size: 1rem;
  }

  .core-subtitle {
    font-size: 0.72rem;
    color: #7eeeff;
  }

  .skill-label {
    position: absolute;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color) 45%, rgba(255, 255, 255, 0.1));
    background: linear-gradient(135deg, rgba(7, 18, 43, 0.92), rgba(25, 9, 54, 0.88));
    box-shadow:
      0 0 18px color-mix(in srgb, var(--color) 22%, transparent),
      inset 0 0 14px rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
  }

  .skill-beacon {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--color) 16%, transparent),
      0 0 16px color-mix(in srgb, var(--color) 70%, transparent);
    flex-shrink: 0;
  }

  .skill-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: #edf6ff;
    text-shadow: 0 0 14px color-mix(in srgb, var(--color) 45%, transparent);
    white-space: nowrap;
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--primary);
    border: 3px solid var(--card-bg);
  }

  .timeline-content {
    padding-left: 0.5rem;
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .timeline-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .timeline-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .contact-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .contact-link:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px var(--shadow);
  }

  @keyframes orbit {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    .about-header {
      padding: 2rem 0;
    }

    .avatar {
      width: 100px;
      height: 100px;
    }

    .about-header h1 {
      font-size: 1.5rem;
    }

    .skill-panel {
      padding: 1.25rem 0.5rem;
    }

    .skill-chart-wrap {
      width: 100%;
      min-height: 420px;
    }

    .skill-chart {
      inset: 24%;
    }

    .skill-label {
      padding: 0.35rem 0.55rem;
    }

    .skill-name {
      font-size: 0.76rem;
    }
  }
</style>
