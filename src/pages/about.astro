---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_AUTHOR } from '../consts';

// 个人信息
const personalInfo = {
  name: SITE_AUTHOR,
  bio: '记录生活中的点滴美好',
  avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=yunn',
  location: '中国',
  email: 'your@email.com',
};

// 技能标签
const skills = [
  { name: 'JavaScript', level: 90 },
  { name: 'TypeScript', level: 85 },
  { name: 'React', level: 88 },
  { name: 'Vue', level: 80 },
  { name: 'Node.js', level: 75 },
  { name: 'Python', level: 70 },
  { name: 'Git', level: 85 },
  { name: 'CSS/Sass', level: 90 },
];

// 社交链接
const socialLinks = [
  { name: 'GitHub', url: 'https://github.com', icon: 'github' },
  { name: 'Twitter', url: 'https://twitter.com', icon: 'twitter' },
  { name: '邮箱', url: 'mailto:your@email.com', icon: 'mail' },
];

// 经历时间线
const timeline = [
  {
    year: '2026',
    title: '开始写博客',
    description: '创建个人博客，记录生活和技术学习',
  },
  {
    year: '2025',
    title: '学习前端开发',
    description: '深入学习 React、Vue 等前端框架',
  },
  {
    year: '2024',
    title: '接触编程',
    description: '开始学习编程，入门计算机世界',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`关于 - ${SITE_TITLE}`} description="关于本站" />
  </head>
  <body>
    <Header />
    <main class="about-page">
      <div class="about-header">
        <div class="avatar">
          <img src={personalInfo.avatar} alt={personalInfo.name} />
        </div>
        <h1>{personalInfo.name}</h1>
        <p class="bio">{personalInfo.bio}</p>
        <div class="social-links">
          {socialLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-link">
              {link.icon === 'github' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
              )}
              {link.icon === 'twitter' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                </svg>
              )}
              {link.icon === 'mail' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              )}
              <span>{link.name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="about-content">
        <section class="about-section">
          <h2>关于我</h2>
          <p>
            你好！欢迎来到我的小角落。这里是 {personalInfo.name}，一个热爱生活、喜欢记录的人。
          </p>
          <p>
            这个博客主要用来分享生活中的随笔、感悟和美好瞬间，以及一些技术学习的心得体会。希望我的文字能给你带来一些温暖和启发。
          </p>
          <p>
            我相信记录的力量，每一个当下的瞬间都值得被珍藏。无论是代码中的思考，还是生活中的感悟，我都希望能在这里留下痕迹。
          </p>
        </section>

        <section class="about-section">
          <h2>技能</h2>
          <div class="skills-container">
            {skills.map((skill) => (
              <div class="skill-item">
                <div class="skill-info">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-level">{skill.level}%</span>
                </div>
                <div class="skill-bar">
                  <div class="skill-progress" style={`width: ${skill.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="about-section">
          <h2>经历</h2>
          <div class="timeline">
            {timeline.map((item, index) => (
              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <span class="timeline-year">{item.year}</span>
                  <h3 class="timeline-title">{item.title}</h3>
                  <p class="timeline-desc">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section class="about-section">
          <h2>关于本站</h2>
          <p>
            本站使用 <a href="https://astro.build" target="_blank">Astro</a> 构建，
            部署在 <a href="https://pages.github.com" target="_blank">GitHub Pages</a> 上。
          </p>
          <p>主要功能包括：</p>
          <ul class="feature-list">
            <li>📝 随笔记录生活点滴</li>
            <li>🏷️ 分类和标签整理</li>
            <li>🔍 全站搜索</li>
            <li>🌙 暗黑模式支持</li>
            <li>📡 RSS 订阅</li>
            <li>💬 评论互动</li>
            <li>📱 移动端适配</li>
          </ul>
        </section>

        <section class="about-section">
          <h2>联系方式</h2>
          <p>如果你有任何想法或建议，欢迎通过以下方式联系我：</p>
          <div class="contact-links">
            <a href={`mailto:${personalInfo.email}`} class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              邮箱
            </a>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              GitHub
            </a>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .about-header {
    text-align: center;
    padding: 3rem 0;
  }

  .avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    padding: 3px;
  }

  .avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--card-bg);
  }

  .about-header h1 {
    margin-bottom: 0.5rem;
    font-size: 2rem;
  }

  .bio {
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
    font-size: 1.1rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .social-link:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .about-section {
    margin-bottom: 2.5rem;
  }

  .about-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-section ul {
    list-style: none;
    padding: 0;
  }

  .about-section li {
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .feature-list li {
    padding: 0.5rem 0;
  }

  .skills-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-item {
    width: 100%;
  }

  .skill-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .skill-name {
    font-weight: 500;
    color: var(--text);
  }

  .skill-level {
    color: var(--text-muted);
  }

  .skill-bar {
    width: 100%;
    height: 8px;
    background: var(--border);
    border-radius: 9999px;
    overflow: hidden;
  }

  .skill-progress {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    border-radius: 9999px;
    transition: width 0.3s ease;
  }

  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--primary);
    border: 3px solid var(--card-bg);
  }

  .timeline-content {
    padding-left: 0.5rem;
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .timeline-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .timeline-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .contact-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .contact-link:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px var(--shadow);
  }

  @media (max-width: 768px) {
    .about-header {
      padding: 2rem 0;
    }

    .avatar {
      width: 100px;
      height: 100px;
    }

    .about-header h1 {
      font-size: 1.5rem;
    }

    .social-links {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
