---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Comments from '../components/Comments.astro';
import friendLinks from '../data/friend-links.json';
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils/paths';

const siteInfo = {
  name: 'YUNN-BLOG',
  author: '芠芸',
  url: 'https://jjyun-ustc.github.io/yunn-blog/',
  description: '直面生活的痛击',
  avatar: 'https://api.dicebear.com/7.x/avataaars/svg?seed=wenyun',
};

const approvedLinks = friendLinks.approved ?? [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`相关链接 - ${SITE_TITLE}`} description="相关链接推引" />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>相关链接</h1>
        <p class="page-desc">相关链接推引</p>
      </div>

      <section class="my-info">
        <h2>本站信息</h2>
        <div class="info-card">
          <div class="info-avatar">
            <img src={siteInfo.avatar} alt={siteInfo.name} />
          </div>
          <div class="info-content">
            <h3>{siteInfo.name}</h3>
            <p class="info-author">博主：{siteInfo.author}</p>
            <p class="info-desc">{siteInfo.description}</p>
            <div class="info-url">
              <span>网址：</span>
              <a href={siteInfo.url} target="_blank" rel="noopener noreferrer">{siteInfo.url}</a>
            </div>
          </div>
        </div>
      </section>

      <section class="friends-section">
        <div class="section-heading">
          <h2>相关链接展示</h2>
          <a href={withBase('admin/')} target="_blank" rel="noreferrer">后台处理展示</a>
        </div>

        {approvedLinks.length > 0 ? (
          <div class="friends-grid">
            {approvedLinks.map((friend) => (
              <a href={friend.url} target="_blank" rel="noopener noreferrer" class="friend-card">
                <div class="friend-avatar">
                  <img src={withBase(friend.avatar)} alt={friend.name} loading="lazy" />
                </div>
                <div class="friend-content">
                  <h3>{friend.name}</h3>
                  <p>{friend.description}</p>
                </div>
                <div class="friend-link-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="no-friends">当前还没有公开展示的相关链接，欢迎在下方留言申请。</p>
        )}
      </section>

      <section class="apply-section">
        <h2>申请展示</h2>
        <div class="apply-content">
          <p class="apply-note">
            <strong>注意事项：</strong>请在下方留言中留下站点名称、链接、简介和头像地址；我会自行处理，并在审核后选择是否展示在上方区域。
          </p>
        </div>
        <Comments />
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    margin: 0 0 0.5rem;
  }

  .page-desc {
    color: var(--text-muted);
    margin: 0;
  }

  .my-info,
  .friends-section,
  .apply-section {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-heading h2 {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .section-heading a {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .info-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: box-shadow 0.2s;
  }

  .info-card:hover {
    box-shadow: 0 8px 16px var(--shadow);
  }

  .info-avatar {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--gradient-start);
  }

  .info-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info-content {
    flex: 1;
  }

  .info-content h3 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .info-author {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0 0 0.5rem;
  }

  .info-desc {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
  }

  .info-url {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .info-url a {
    color: var(--primary);
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .friend-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    align-items: center;
  }

  .friend-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px var(--shadow);
    border-color: var(--primary);
  }

  .friend-avatar {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--gradient-start);
  }

  .friend-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .friend-content {
    flex: 1;
    min-width: 0;
  }

  .friend-content h3 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
    color: var(--text);
  }

  .friend-content p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .friend-link-icon {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .friend-card:hover .friend-link-icon {
    color: var(--primary);
  }

  .no-friends {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    background: var(--card-bg);
    border: 1px dashed var(--border);
    border-radius: 12px;
  }

  .apply-content {
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .apply-note {
    padding: 1rem;
    background: var(--gradient-start);
    border-radius: 8px;
    margin: 0;
    color: var(--text);
  }

  @media (max-width: 768px) {
    .info-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .section-heading {
      flex-direction: column;
      align-items: flex-start;
    }

    .friends-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
