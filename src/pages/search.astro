---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
const basePath = import.meta.env.BASE_URL;

const posts = await getCollection('blog');
const searchablePosts = posts
  .filter((post) => !post.data.draft)
  .map((post) => ({
    slug: post.id,
    title: post.data.title,
    description: post.data.description,
    category: post.data.category || '随笔',
    tags: post.data.tags || [],
    pubDate: post.data.pubDate.toISOString(),
  }));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`搜索 - ${SITE_TITLE}`} description="搜索文章" />
  </head>
  <body>
    <Header />
    <main class="shell">
      <section class="page-hero">
        <span class="eyebrow">query mode</span>
        <h1>搜索</h1>
        <p class="page-desc">把查找入口从一根输入框，升级成更完整的检索区域。</p>
      </section>
      <section class="page-grid">
        <div class="page-main-column">
          <div class="card-surface">
            <div class="search-container">
              <input
                type="text"
                id="search-input"
                placeholder="输入关键词搜索..."
                autocomplete="off"
              />
            </div>
            <div id="search-results" class="search-results"></div>
          </div>
        </div>
        <aside class="page-side-column">
          <div class="side-card">
            <h3>Search Scope</h3>
            <p>标题、描述、标签、分类都会被检索到。</p>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script define:vars={{ searchablePosts, basePath }}>
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      const posts = searchablePosts;

      function search(query) {
        if (!query.trim()) {
          searchResults.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
          return;
        }

        const q = query.toLowerCase();
        const results = posts.filter(post => {
          return post.title.toLowerCase().includes(q) ||
                 post.description.toLowerCase().includes(q) ||
                 post.tags.some(tag => tag.toLowerCase().includes(q)) ||
                 post.category.toLowerCase().includes(q);
        });

        if (results.length === 0) {
          searchResults.innerHTML = '<p class="no-results">没有找到相关文章</p>';
          return;
        }

        searchResults.innerHTML = results.map(post => `
          <a href="${basePath}blog/${post.slug}/" class="search-result-item">
            <span class="result-category">${post.category}</span>
            <h3 class="result-title">${post.title}</h3>
            <p class="result-desc">${post.description}</p>
            <div class="result-tags">
              ${post.tags.map(tag => `<span class="tag">${tag}</span>`).join('')}
            </div>
          </a>
        `).join('');
      }

      searchInput.addEventListener('input', (e) => {
        search(e.target.value);
      });

      searchResults.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
    </script>
  </body>
</html>

<style>
  .page-desc { color: var(--text-muted); margin: 0; }
  .search-container { margin-bottom: 1.5rem; }
  #search-input {
    width: 100%;
    padding: 1rem 1.25rem;
    font-size: 1.08rem;
    border: 2px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.42);
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  #search-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 4px rgba(234, 88, 12, 0.1); }
  .search-results { display: flex; flex-direction: column; gap: 1rem; }
  .search-hint, .no-results { color: var(--text-muted); text-align: center; padding: 2rem; }
  .search-result-item {
    display: block;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.32);
    border: 1px solid var(--border);
    border-radius: 20px;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .search-result-item:hover { transform: translateY(-2px); box-shadow: 0 12px 24px var(--shadow); border-color: var(--primary); }
  .result-category {
    display: inline-block;
    font-size: 0.75rem;
    color: white;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    margin-bottom: 0.5rem;
  }
  .result-title { margin: 0 0 0.5rem; font-size: 1.1rem; }
  .result-desc { margin: 0 0 0.75rem; color: var(--text-secondary); font-size: 0.9rem; }
  .result-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
</style>
