---
const serverURL = import.meta.env.PUBLIC_WALINE_SERVER_URL || '';
const placeholder = import.meta.env.PUBLIC_WALINE_PLACEHOLDER || '写下你路过这里时的心情吧...';
const avatar = import.meta.env.PUBLIC_WALINE_AVATAR || 'mp';
const requiredMeta = import.meta.env.PUBLIC_WALINE_REQUIRED_META || 'nick';
const pageSize = Number(import.meta.env.PUBLIC_WALINE_PAGE_SIZE || '8');
const lang = import.meta.env.PUBLIC_WALINE_LANG || 'zh-CN';
const login = import.meta.env.PUBLIC_WALINE_LOGIN || 'disable';
const isConfigured = Boolean(serverURL);
---

<section class="side-card guestbook-card">
  <div class="guestbook-header">
    <div>
      <p class="guestbook-tag">guestbook</p>
      <h3>留言板</h3>
    </div>
  </div>

  {isConfigured ? (
    <div id="guestbook-thread" class="guestbook-thread"></div>
  ) : (
    <div class="guestbook-thread"></div>
  )}
</section>

<script
  define:vars={{ serverURL, placeholder, avatar, requiredMeta, pageSize, lang, login, isConfigured }}
>
  const mount = document.getElementById('guestbook-thread');

  function ensureWalineStyles() {
    if (document.querySelector('link[data-guestbook-waline-style]')) return;

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/@waline/client@v3/dist/waline.css';
    link.dataset.guestbookWalineStyle = 'true';
    document.head.appendChild(link);
  }

  async function loadWaline() {
    if (window.__guestbookWalineInit) return window.__guestbookWalineInit;

    window.__guestbookWalineInit = import('https://unpkg.com/@waline/client@v3/dist/waline.js');
    return window.__guestbookWalineInit;
  }

  async function initGuestbook() {
    if (!mount || !isConfigured) return;

    try {
      ensureWalineStyles();
      const { init } = await loadWaline();

      init({
        el: '#guestbook-thread',
        serverURL,
        path: '/guestbook/home',
        lang,
        placeholder,
        avatar,
        requiredMeta: requiredMeta
          .split(',')
          .map((field) => field.trim())
          .filter(Boolean),
        pageSize,
        meta: ['nick', 'mail'],
        login,
      });
    } catch (error) {
      mount.innerHTML = '<div class="guestbook-runtime-error">留言板加载失败，请稍后再试。</div>';
      console.error('Guestbook failed to load', error);
    }
  }

  initGuestbook();
</script>

<style>
  .guestbook-card {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background:
      radial-gradient(circle at top right, rgba(255, 196, 126, 0.3), transparent 34%),
      radial-gradient(circle at left bottom, rgba(91, 140, 255, 0.18), transparent 38%),
      linear-gradient(160deg, rgba(255, 252, 246, 0.95), rgba(245, 248, 255, 0.92));
    overflow: hidden;
  }

  .guestbook-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .guestbook-tag {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .guestbook-header h3 {
    margin: 0;
    font-size: 1.45rem;
  }

  .guestbook-runtime-error {
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid rgba(91, 140, 255, 0.16);
    background: rgba(255, 255, 255, 0.68);
    color: var(--text-secondary);
  }

  .guestbook-runtime-error {
    margin: 0;
    line-height: 1.7;
  }

  .guestbook-thread {
    min-height: 220px;
    padding: 0.2rem;
  }

  :global(.guestbook-card .wl-editor),
  :global(.guestbook-card .wl-panel),
  :global(.guestbook-card .wl-card),
  :global(.guestbook-card .wl-sort),
  :global(.guestbook-card .wl-empty),
  :global(.guestbook-card .wl-login-info) {
    border-radius: 20px;
    border-color: rgba(91, 140, 255, 0.16);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: none;
  }

  :global(.guestbook-card .wl-editor) {
    padding: 0.4rem;
  }

  :global(.guestbook-card .wl-input),
  :global(.guestbook-card .wl-editor textarea),
  :global(.guestbook-card .wl-card .wl-content) {
    color: var(--text);
  }

  :global(.guestbook-card .wl-meta-input),
  :global(.guestbook-card .wl-meta-input::placeholder),
  :global(.guestbook-card .wl-input::placeholder),
  :global(.guestbook-card .wl-time),
  :global(.guestbook-card .wl-info),
  :global(.guestbook-card .wl-empty),
  :global(.guestbook-card .wl-count),
  :global(.guestbook-card .wl-sort li) {
    color: var(--text-muted);
  }

  :global(.guestbook-card .wl-btn.primary) {
    border-radius: 999px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, #4f46e5, #f59e0b);
    color: #fff;
  }

  :global(.guestbook-card .wl-btn.primary:hover) {
    opacity: 0.92;
  }

  :global(.guestbook-card .wl-content p) {
    color: var(--text);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .guestbook-card {
      padding: 1rem;
    }

    .guestbook-header {
      align-items: stretch;
      flex-direction: column;
    }

  }
</style>
